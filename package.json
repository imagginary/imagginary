{
  "name": "imagginary",
  "version": "1.0.93",
  "description": "Imagginary — local-first AI storyboard generator for filmmakers",
  "main": "public/electron.mjs",
  "scripts": {
    "dev:renderer": "webpack serve --config webpack.config.js",
    "dev:electron": "wait-on http://localhost:3000 && ELECTRON_RUN_AS_NODE= ELECTRON_START_URL=http://localhost:3000 electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "prebuild": "node scripts/generate-icons.js",
    "build": "cross-env NODE_ENV=production webpack --config webpack.config.js",
    "start": "electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run prebuild && npm run build && electron-builder",
    "setup:ollama": "bash scripts/download-ollama.sh"
  },
  "keywords": [
    "storyboard",
    "filmmaking",
    "ai",
    "electron",
    "ollama",
    "comfyui"
  ],
  "author": "Imagginary",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.imagginary.app",
    "productName": "Imagginary",
    "icon": "build/icon.png",
    "afterSign": "scripts/notarize.js",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "public/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "resources/**/*",
      "public/loading.html"
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "artifactName": "${productName}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "assets/entitlements.mac.plist",
      "entitlementsInherit": "assets/entitlements.mac.plist",
      "extraResources": [
        {
          "from": "resources/config.json",
          "to": "config.json"
        },
        {
          "from": "resources/motion_library",
          "to": "motion_library"
        },
        {
          "from": "resources/ollama/mac",
          "to": "bin"
        },
        {
          "from": "resources/bin/ffmpeg-mac",
          "to": "bin/ffmpeg-mac"
        },
        {
          "from": "resources/bin/ffprobe-mac",
          "to": "bin/ffprobe-mac"
        },
        {
          "from": "resources/sounds",
          "to": "sounds"
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "extraResources": [
        {
          "from": "resources/config.json",
          "to": "config.json"
        },
        {
          "from": "resources/motion_library",
          "to": "motion_library"
        },
        {
          "from": "resources/ollama/win",
          "to": "bin"
        },
        {
          "from": "resources/bin/ffmpeg-win.exe",
          "to": "bin/ffmpeg-win.exe"
        },
        {
          "from": "resources/bin/ffprobe-win.exe",
          "to": "bin/ffprobe-win.exe"
        },
        {
          "from": "resources/sounds",
          "to": "sounds"
        }
      ]
    },
    "dmg": {
      "title": "Imagginary",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Imagginary",
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "artifactName": "${productName}-Setup.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "category": "Graphics",
      "artifactName": "${productName}-${arch}.${ext}",
      "extraResources": [
        {
          "from": "resources/config.json",
          "to": "config.json"
        },
        {
          "from": "resources/motion_library",
          "to": "motion_library"
        },
        {
          "from": "resources/bin/ffmpeg-linux",
          "to": "bin/ffmpeg-linux"
        },
        {
          "from": "resources/bin/ffprobe-linux",
          "to": "bin/ffprobe-linux"
        },
        {
          "from": "resources/sounds",
          "to": "sounds"
        }
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "imagginary",
      "repo": "imagginary"
    }
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@electron/notarize": "^3.1.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "babel-loader": "^10.1.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.6",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.5.9",
    "postcss-loader": "^8.2.1",
    "sharp": "^0.34.5",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.2",
    "wait-on": "^9.0.4",
    "webpack": "^5.106.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "@types/three": "^0.184.1",
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.3",
    "jspdf": "^4.2.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "three": "^0.184.0"
  }
}
