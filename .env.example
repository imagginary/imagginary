# Imagginary — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# ── Phase 6C — Motion Library Builder ─────────────────────────────────────────
# Required to run scripts/build_motion_library.py (offline, run once).
# Get a free key at: https://www.pexels.com/api/
# The bundled 20-clip starter library works WITHOUT this key.
PEXELS_API_KEY=your_pexels_api_key_here

# ── Optional overrides ─────────────────────────────────────────────────────────
# Ollama endpoint (default: http://localhost:11434)
# OLLAMA_URL=http://localhost:11434

# OpenPose binary path — enables real pose extraction from videos (GPU required)
# Leave blank to use synthetic pose sequences instead.
# OPENPOSE_BIN=/path/to/openpose

# FFmpeg binary path (default: ffmpeg in PATH)
# FFMPEG_BIN=/opt/homebrew/bin/ffmpeg

# ── Shared Fal.ai key (baked in at build time) ────────────────────────────────
# Powers Director's Eye AI inpainting and character face consistency for Pro/Studio
# users without requiring them to supply their own key. Embedded in the renderer
# bundle at build time via webpack DefinePlugin — never exposed in the UI.
# Add to GitHub Actions secrets as FAL_API_KEY.
FAL_API_KEY=your_fal_api_key_here

# ── Shared Sync.so key (baked in at build time) ───────────────────────────────
# Powers lip sync animation for Pro/Studio users. Add to GitHub Actions secrets
# as SYNCSO_API_KEY.
SYNCSO_API_KEY=

# ── Shared DeepSeek key (baked in at build time) ──────────────────────────────
# Powers cloud shot parsing for Pro/Studio users. Add to GitHub Actions secrets
# as DEEPSEEK_API_KEY.
DEEPSEEK_API_KEY=

# ── Telemetry (opt-in, Umami Cloud) ───────────────────────────────────────────
# Get a free website ID at https://umami.is — add it to GitHub Actions secrets
# as UMAMI_WEBSITE_ID. Leave blank for local dev (telemetry is silently skipped).
UMAMI_WEBSITE_ID=your_umami_website_id_here

# ── Dodo Payments (annual billing) ────────────────────────────────────────────
DODO_PRO_ANNUAL_CHECKOUT_URL=
DODO_STUDIO_ANNUAL_CHECKOUT_URL=
DODO_STARTER_CREDITS_URL=
DODO_STANDARD_CREDITS_URL=
DODO_POWER_CREDITS_URL=
